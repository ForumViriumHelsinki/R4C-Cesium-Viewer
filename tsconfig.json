{
	"compilerOptions": {
		// Enable JavaScript file processing
		"allowJs": true,
		// Enable type-checking for better DX and error catching
		"checkJs": true,
		// Recommended for Vite - ensures each file can be safely transpiled in isolation
		"isolatedModules": true,

		// Target modern JavaScript to match Vite config
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",

		// Allow default imports from modules with no default export
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,

		// Skip type checking of declaration files
		"skipLibCheck": true,

		// Granular strict mode configuration for gradual adoption
		// We enable specific strict checks while keeping 'strict' false to avoid breaking existing code
		"strict": false, // Keep false - enables all strict flags at once, too aggressive for existing codebase
		"noImplicitAny": false, // TODO: Enable once JSDoc types are added to critical functions
		"strictNullChecks": true, // ENABLED: Catches null/undefined errors, high-value check
		"strictFunctionTypes": true, // ENABLED: Ensures function parameter compatibility, low friction
		"strictPropertyInitialization": false, // Disabled: Many Vue components don't initialize all properties
		"noImplicitThis": true, // ENABLED: Prevents `this` binding errors in callbacks

		// Resolve JSON modules
		"resolveJsonModule": true,

		// Ensure consistent casing in imports
		"forceConsistentCasingInFileNames": true,

		// Match Vite's path alias configuration
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		},
		// Silence the TS5101 deprecation warning for `baseUrl` until a follow-up
		// PR migrates to `paths`-only resolution. Required for TypeScript 6.x;
		// `baseUrl` is removed in TypeScript 7.0.
		"ignoreDeprecations": "6.0",

		// Library types
		"lib": ["ES2020", "DOM", "DOM.Iterable"]
	},
	"include": ["src/**/*.js", "src/**/*.vue"],
	"exclude": ["node_modules", "dist", "tests", "**/*.spec.js", "**/*.test.js"]
}
