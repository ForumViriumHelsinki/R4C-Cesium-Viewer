# EditorConfig — https://editorconfig.org
# Mirrors biome.json (tab indent, width 2, 100-col) and pre-commit hygiene hooks.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2
tab_width = 2
max_line_length = 100

# Markdown: trailing whitespace is significant (hard line breaks)
[*.md]
trim_trailing_whitespace = false

# YAML does not permit tabs for indentation
[*.{yml,yaml}]
indent_style = space
indent_size = 2
