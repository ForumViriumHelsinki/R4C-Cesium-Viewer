{
	"name": "r4c-cesium-viewer",
	"private": true,
	"license": "MIT",
	"version": "1.52.0",
	"type": "module",
	"scripts": {
		"dev": "vite --host",
		"dev:test": "VITE_E2E_TEST=true vite --host",
		"build": "NODE_OPTIONS='--max-old-space-size=3072' vite build && bun scripts/precompress.mjs",
		"build:analyze": "NODE_OPTIONS='--max-old-space-size=3072' vite build --mode analyze",
		"preview": "vite preview --host",
		"lint": "biome check src/",
		"typecheck": "vue-tsc --noEmit",
		"lint:fix": "biome check --write src/",
		"lint:deps": "knip",
		"format": "biome format --write src/",
		"format:check": "biome format src/",
		"check": "biome check --write .",
		"docs": "typedoc",
		"docs:serve": "bun run docs && bunx http-server docs -p 8080 -o",
		"test": "vitest",
		"test:unit": "vitest run tests/unit",
		"test:integration": "vitest run tests/integration",
		"test:e2e": "playwright test tests/e2e",
		"test:e2e:mock": "playwright test tests/e2e --grep-invert @requires-database",
		"test:performance": "vitest run --config vitest.performance.config.js",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:accessibility": "playwright test tests/e2e/accessibility",
		"test:accessibility:mock": "playwright test tests/e2e/accessibility --grep-invert @requires-database",
		"test:accessibility:desktop": "playwright test tests/e2e/accessibility --project=accessibility-desktop",
		"test:accessibility:tablet": "playwright test tests/e2e/accessibility --project=accessibility-tablet",
		"test:accessibility:mobile": "playwright test tests/e2e/accessibility --project=accessibility-mobile",
		"test:accessibility:all-viewports": "bun run test:accessibility:desktop && bun run test:accessibility:tablet && bun run test:accessibility:mobile",
		"test:accessibility:watch": "playwright test tests/e2e/accessibility --ui",
		"test:accessibility:report": "playwright show-report",
		"test:accessibility:focused": "playwright test tests/e2e/accessibility/ --workers=1 --max-failures=1",
		"test:accessibility:file": "playwright test --workers=1 --max-failures=1",
		"test:layer-controls": "bun run test:accessibility:file tests/e2e/accessibility/layer-controls.spec.ts",
		"test:building-filters": "bun run test:accessibility:file tests/e2e/accessibility/building-filters.spec.ts",
		"test:navigation-levels": "bun run test:accessibility:file tests/e2e/accessibility/navigation-levels.spec.ts",
		"test:expansion-panels": "bun run test:accessibility:file tests/e2e/accessibility/expansion-panels.spec.ts",
		"test:timeline-controls": "bun run test:accessibility:file tests/e2e/accessibility/timeline-controls.spec.ts",
		"test:view-modes": "bun run test:accessibility:file tests/e2e/accessibility/view-modes.spec.ts",
		"test:comprehensive-walkthrough": "bun run test:accessibility:file tests/e2e/accessibility/comprehensive-walkthrough.spec.ts",
		"test:all": "bun run test:unit && bun run test:integration && bun run test:e2e",
		"test:ci": "bun run test:coverage && bun run test:e2e",
		"test:ci:accessibility": "bun run test:accessibility:all-viewports",
		"test:performance:monitor": "PERFORMANCE_MONITORING=true playwright test tests/e2e/accessibility",
		"test:performance:check": "bun scripts/check-performance-regression.js",
		"test:performance:baseline": "PERFORMANCE_MONITORING=true playwright test tests/e2e/accessibility && echo 'Baseline generated in tests/performance-baselines.json'",
		"test:e2e:errors-only": "mkdir -p test-results && playwright test --reporter=line,json=test-results/test-results.json,blob --quiet 2> test-results/run.stderr.log | tee test-results/run.stdout.log",
		"test:e2e:failed": "playwright test --last-failed --reporter=line,json=test-results/test-results.json",
		"test:e2e:changed": "playwright test --only-changed --reporter=dot",
		"test:e2e:triage": "jq '.stats' test-results/test-results.json && jq -r '.suites[] | .. | objects | select(.tests?) | .tests[] | select(any(.results[]; .status==\"failed\")) | \"\\(.location.file):\\(.location.line)  \\(.title)\"' test-results/test-results.json"
	},
	"dependencies": {
		"@deck.gl/core": "^9",
		"@deck.gl/geo-layers": "^9",
		"@deck.gl/layers": "^9",
		"@mdi/js": "^7.4.47",
		"@openfeature/go-feature-flag-web-provider": "^0.2.7",
		"@openfeature/web-sdk": "^1.7.2",
		"@sentry/browser": "^10.54.0",
		"@sentry/vue": "^10.54.0",
		"@turf/turf": "^7.3.5",
		"axios": "^1.16.1",
		"cesium": "^1.141.0",
		"d3": "^7.9.0",
		"d3-array": "^3.2.4",
		"d3-axis": "^3.0.0",
		"d3-scale": "^4.0.2",
		"d3-scale-chromatic": "^3.1.0",
		"d3-selection": "^3.0.0",
		"d3-shape": "^3.2.0",
		"fast-xml-parser": "^5.8.0",
		"mitt": "^3.0.1",
		"pinia": "^3.0.4",
		"tiff-imagery-provider": "^2.17.2",
		"unplugin-vue-components": "^32.0.0",
		"vite-plugin-vuetify": "^2.1.2",
		"vue": "^3.5.25",
		"vuetify": "^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.9",
		"@playwright/test": "^1.57.0",
		"@sentry/vite-plugin": "^5.3.0",
		"@vitejs/plugin-vue": "^6.0.3",
		"@vitest/coverage-v8": "^4.0.15",
		"@vue/test-utils": "^2.4.6",
		"globals": "^17.0.0",
		"jsdom": "^29.0.0",
		"knip": "^6.1.0",
		"rollup-plugin-visualizer": "^7.0.0",
		"sass-embedded": "^1.98.0",
		"typedoc": "^0.28.15",
		"typescript": "5.9.3",
		"unplugin-auto-import": "^21.0.0",
		"vite": "^8.0.1",
		"vite-plugin-cesium-build": "^0.7.2",
		"vitest": "^4.0.15",
		"vue-tsc": "3.3.3"
	},
	"overrides": {
		"esbuild": "^0.28.0",
		"postcss": "^8.5.10",
		"brace-expansion": "^5.0.6",
		"yaml": "^2.8.3",
		"minimatch": "^9.0.6",
		"js-cookie": "^3.0.8",
		"markdown-it": "^14.2.0",
		"picomatch": "^4.0.4",
		"rollup": "^4.59.0"
	}
}
